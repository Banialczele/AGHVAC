html,
body {
    overscroll-behavior: none;
    overflow: auto;
    font-family: 'Open Sans', Arial, Helvetica, sans-serif;
    font-size: 14px;
    min-width: 950px;
}

*,
*::before,
*::after {
    box-sizing: border-box;
}

body {
    margin: 0;
    width: 100vw;
    height: 100vh;
}

.powerManagementContainer {
    width: 100%;
    margin: 0 auto;
}


/* styles to remove arrows from input element */

#quantity,
input::-webkit-outer-spin-button,
#quantity,
input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

#quantity,
input[name="cableInput"] {
    width: 80px;
    -moz-appearance: textfield;
}

.languageVersions {
    width: 100px;
    display: flex;
    flex-direction: column;
}

.languageVersions>a {
    flex: 1;
    color: inherit;
    margin-left: auto;
    justify-content: start;
    font-size: 10px;
}

.languageVersions>a:hover {
    color: #333;
}

select {
    padding: 5px 10px;
    text-align: center;
    border-radius: 5px;
    border: 1px;
    background: rgb(215, 215, 215);
    -moz-appearance: none;
    /* Firefox */
    -webkit-appearance: none;
    /* Safari and Chrome */
}

select.deviceSelect {
    width: 160px;
}

select.powerSupply {
    width: auto;
}

p {
    margin: 0;
}

*:focus {
    outline: none;
}


/* .systemStatus {
    margin: 0 auto;
    max-width: 40%;
    min-width: 250px;
    height: 80px; 
    background: rgba(255, 255, 255, 0.4);
    padding: 0 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
