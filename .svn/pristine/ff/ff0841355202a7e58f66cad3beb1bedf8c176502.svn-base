/* .systemWrongMessages {
    display: none;
} */

.systemStatus .systemWrongActiveMessage {
    align-self: center;
}

.showMoreButton {
    background: inherit;
}

.systemWrongActiveMessage {
    display: block;
    text-overflow: ellipsis;
    width: 320px;
    /*white-space: nowrap;*/
    /*overflow: hidden;*/
    margin: 0;
    padding: 5px 10px;
}

.systemStatusContainer {
    display: flex;
    flex-direction: column;
    position: fixed;
    left: 5px;
    z-index: 0;
    margin-left: 15px;
}

.systemInfo {
    background: rgba(210, 210, 210, 1);
    /*text-overflow: ellipsis;*/
	/*overflow-wrap: break-word;*/
    /*overflow: hidden;*/
    /*white-space: nowrap;*/
    padding: 10px 5px;
    border-radius: 15px;
    transition: width .2s, height .2s;
}

.systemInfoBig {
    height: 250px;
    width: 330px;
}

.systemInfoSmall {
    height: 80px;
    width: 110px;
}

.systemStatus {
    margin: 20px 0;
}

.sys {
    width: 100%;
    display: flex;
    align-items: center;
    flex-direction: row;
    justify-content: flex-start;
}

.systemStatusDescription {
    display: inline-block;
    margin-right: 10px;
}

.systemStatusText {
    display: inline-block;
    width: 20px;
    height: 20px;
}

.systemStatusText img {
    width: 100%;
    height: 100%;
}

.popup {
    max-width: 200px;
    background: rgba(23, 20, 20, 0.8);
    color: white;
    padding: 15px 10px;
    transform: translateY(-500%);
}

.open-active {
    transform: translateX(10%) translateY(-80%);
    border-radius: 15px;
}


.systemWrongList > li {
    /*list-style: none; */
}

.systemWrongList
{
	overflow-wrap: break-word;
}

img {
    width: 100%;
}

.sticky {
    position: fixed;
    top: 50px;
    left: 20px;
    z-index: 9999;
}

.licenseDiv {
    margin: 15px auto;
    max-width: 50%;
    min-width: 650px;
    height: 50px;
}

input,
button {
    background: #FFFFFF;
    border-radius: 5px;
    border: none;
}

#header {
    margin: 15px auto 35px;
    max-width: 40%;
    min-width: 650px;
    background: rgba(255, 255, 255, 0.4);
    border-bottom: 1px dotted #222;
    /* padding: 0 15px; */
    display: flex;
    flex-direction: column;
}

#header #headerContainer {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
}

#headerContainer>* {
    flex: 1 0 auto;
}

#header h2 {
    margin: 5px 0;
}

#header #headerImage {
    width: 160px;
    align-self: center;
}

#header p {
    font-size: 12px;
    color: darkgray;
}

.licensedDeleteImage,
.licensedCopyImage {
    height: 20px;
    width: auto;
}

.licenseIntro {
    display: inline;
}

.helpButton img {
    pointer-events: none;
    width: auto;
    height: 30px;
}

.modalHelper {
    display: none;
    /* Hidden by default */
    position: fixed;
    /* Stay in place */
    z-index: 9999;
    /* Sit on top */
    left: 0;
    top: 0;
    width: 100%;
    /* Full width */
    height: 100%;
    /* Full height */
    overflow: auto;
    /* Enable scroll if needed */
    background-color: rgb(0, 0, 0);
    /* Fallback color */
    background-color: rgba(0, 0, 0, 0.4);
    /* Black w/ opacity */
}

.modalContent {
    background-color: #fefefe;
    margin: 15% auto;
    /* 15% from the top and centered */
    padding: 20px;
    border: 1px solid #888;
    width: 80%;
    /* Could be more or less, depending on screen size */
}

.modalClose {
    color: #aaa;
    float: right;
    font-size: 28px;
    font-weight: bold;
}

.modalClose:hover,
.close:focus {
    color: black;
    text-decoration: none;
    cursor: pointer;
}

.deleteManyButton:hover,
.copyButton:hover,
.deleteButton:hover,
.helpButton:hover {
    cursor: pointer;
}

